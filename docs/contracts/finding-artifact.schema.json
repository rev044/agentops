{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding Artifact",
  "description": "Canonical schema for normalized prevention findings stored under .agents/findings/ as markdown with YAML frontmatter.",
  "type": "object",
  "required": [
    "id",
    "type",
    "date",
    "source_skill",
    "source_artifact",
    "severity",
    "detectability",
    "status",
    "compiler_targets",
    "scope_tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "finding"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "source_skill": {
      "type": "string",
      "minLength": 1
    },
    "source_artifact": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "detectability": {
      "type": "string",
      "enum": ["advisory", "mechanical"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "retired", "superseded"]
    },
    "compiler_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["plan", "pre-mortem", "constraint"]
      },
      "uniqueItems": true
    },
    "scope_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_bead": {
      "type": "string"
    },
    "source_phase": {
      "type": "string",
      "enum": ["research", "plan", "implement", "validate"]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "enforcement_command": {
      "type": "string"
    },
    "content_pattern": {
      "type": "string"
    },
    "retired_by": {
      "type": "string"
    },
    "supersedes": {
      "type": "string"
    },
    "superseded_by": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
