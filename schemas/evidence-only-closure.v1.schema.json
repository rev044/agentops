{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/evidence-only-closure.v1.schema.json",
  "title": "AgentOps Evidence-Only Closure Artifact v1",
  "description": "Schema-backed proof artifact for closures that rely on validation or policy evidence instead of a code delta.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "target_id",
    "target_type",
    "created_at",
    "producer",
    "evidence_mode",
    "validation_commands",
    "repo_state",
    "evidence"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^evidence-only-closure-"
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "target_type": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "evidence_mode": {
      "type": "string",
      "enum": ["commit", "staged", "worktree"]
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_root",
        "git_branch",
        "git_dirty",
        "head_sha",
        "modified_files",
        "staged_files",
        "unstaged_files",
        "untracked_files"
      ],
      "properties": {
        "repo_root": {
          "type": "string",
          "minLength": 1
        },
        "git_branch": {
          "type": "string"
        },
        "git_dirty": {
          "type": "boolean"
        },
        "head_sha": {
          "type": "string"
        },
        "modified_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "staged_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unstaged_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "untracked_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "artifacts", "notes"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
